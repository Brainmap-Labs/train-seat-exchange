# =============================================================================
# SeatSwap Backend — copy to backend/.env and fill in values
# =============================================================================

# --- Database (required) ---
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=train_seat_exchange

# --- Auth / JWT (required in production) ---
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Google OAuth (optional — enables Google sign-in) ---
# Same Web client ID as frontend VITE_GOOGLE_CLIENT_ID
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# --- Firebase (optional — for future phone OTP via Firebase) ---
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# --- CORS ---
# Comma-separated list of allowed frontend origins (no trailing slashes)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://train-seat-exchange.vercel.app

# --- Admin (optional — protects /api/exchange/admin/* endpoints) ---
ADMIN_API_KEY=your-admin-api-key

# --- PNR Lookup (optional — recommended over OCR) ---
# Get a free key from https://indianrailapi.com
INDIAN_RAIL_API_KEY=
INDIAN_RAIL_API_URL=https://indianrailapi.com/api/v2

# --- OCR — Ticket image upload ---
# Hugging Face model (large download on first use; GPU optional)
USE_HUGGINGFACE_OCR=false
HUGGINGFACE_MODEL=nanonets/Nanonets-OCR2-3B
# Tesseract fallback (set path if not on PATH)
TESSERACT_CMD=

# --- AI — Ticket parsing & match re-ranking (OpenAI and/or Google Gemini) ---
# AI_PROVIDER: auto (try Gemini then OpenAI) | gemini | openai
AI_PROVIDER=auto
USE_OPENAI_PARSING=true
USE_OPENAI_MATCHING=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_MATCHING_TOP_N=5
