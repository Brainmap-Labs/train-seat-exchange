# =============================================================================
# SeatSwap Frontend — copy to frontend/.env and fill in values
# =============================================================================

# --- API ---
# Leave unset for local dev (Vite proxies /api to the backend)
# Set to full backend URL in production, e.g. https://your-api.onrender.com/api
VITE_API_BASE_URL=

# --- Google OAuth (optional — enables "Sign in with Google") ---
# Same Web client ID as backend GOOGLE_CLIENT_ID
# Authorized JavaScript origins must include http://localhost:3000 and your prod URL
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
